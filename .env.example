# ===== KavachForWork Environment Variables =====
# ⚠️  SECURITY: .env is in .gitignore - NEVER commit real credentials
# Copy this file to .env and fill with YOUR OWN SECURE values before running
# Generated values shown here are PLACEHOLDERS ONLY - replace all before deployment

# MongoDB Atlas Connection
# Format: mongodb+srv://username:password@host/?appName=DatabaseName
# Get credentials from: https://cloud.mongodb.com/v2/projects/{projectId}/clusters
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.kjcvolj.mongodb.net/?appName=Cluster0

# JWT Secret Token
# IMPORTANT: Generate a new random secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_randomly_generated_secret_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=production

# WeatherStack API Key
# Get FREE key from: https://weatherstack.com/signup/free
WEATHERSTACK_API_KEY=your_weatherstack_api_key_here

# OpenWeatherMap API Key (optional backup)
# Get FREE key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OpenAQ API (free, no key needed)
OPENAQ_BASE_URL=https://api.openaq.org/v2

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000
AI_WEATHER_ORACLE_ENABLED=true

# Admin Login Credentials
# SECURITY: Change these immediately after deployment
# Use strong passwords: Mix uppercase, lowercase, numbers, special characters
ADMIN_EMAIL=admin@kavachforwork.in
ADMIN_PASSWORD=your_strong_admin_password_here

# Razorpay Payment Gateway
# Get test keys from: https://dashboard.razorpay.com/app/keys
# NEVER use production keys in development
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# Google Gemini API (for Chatbot)
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Client URL (for CORS - must match your frontend)
CLIENT_URL=http://localhost:5173

# Optional: Sentry Error Monitoring
SENTRY_DSN=your_sentry_dsn_here

# Optional: Redis Cache URL
REDIS_URL=redis://localhost:6379
